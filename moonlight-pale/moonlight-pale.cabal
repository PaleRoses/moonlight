  build-depends:
    base >= 4.18 && < 5
    , array >= 0.5
    , containers >= 0.6
    , directory >= 1.3
    , filepath >= 1.4
    , ghc >= 9.14 && < 9.16
    , moonlight-core >= 0.1
    , moonlight-pale:ghc-surface
    , moonlight-pale:test
    , process >= 1.6
    , tasty >= 1.4
    , tasty-hunit >= 0.10

