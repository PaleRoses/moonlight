  import: shared-properties
  type: exitcode-stdio-1.0
  hs-source-dirs: test test/core test/index test/runtime test/join test/circuit
  main-is: Main.hs
  other-modules:
    BatchDenseSpec
    CircuitSpec
    RowsCacheSpec
    AlgebraSpec
    ArrangementSpec
    BatchTraceSpec
    WCOJDeltaSpec
    IndexSpec
    OperatorSpec
    SupportedViewSpec
    ScheduleSpec
    ProjectionSpec
    RowSpec
    StreamSpec
    WCOJSpec
    TraceCompactionLawSpec
  ghc-options: -rtsopts
  build-depends:
    containers >= 0.6 && < 0.9
    , moonlight-algebra >= 0.1 && < 0.2
    , moonlight-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-epoch >= 0.1 && < 0.2
    , moonlight-differential >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-runtime >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-index >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-circuit >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-join >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-laws >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-test-support >= 0.1 && < 0.2
    , moonlight-algebra:finite-lattice >= 0.1 && < 0.2
    , QuickCheck >= 2.14 && < 2.17
    , tasty >= 1.4 && < 1.6
    , tasty-hunit >= 0.10 && < 0.11
    , tasty-quickcheck >= 0.10 && < 0.12
    , transformers >= 0.6 && < 0.7
    , vector >= 0.13 && < 0.14

benchmark moonlight-differential-bench
  import: shared-properties
  type: exitcode-stdio-1.0
  hs-source-dirs: bench bench/core bench/index bench/runtime bench/join bench/circuit bench/support
  main-is: Main.hs
  other-modules:
    Allocation
    ArrangementJoin
    CircuitFixpoint
    Common
    Groups
    Operator
    Projection
    Relation
    RowIndex
    RowProjection
    RuntimeSettle
    Storage
    Stream
    TraceCompact
    TraceRead
    WCOJ
  ghc-options: -O2 -rtsopts
  build-depends:
    containers >= 0.6 && < 0.9
    , deepseq >= 1.4 && < 1.6
    , moonlight-delta:moonlight-delta-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-epoch >= 0.1 && < 0.2
    , moonlight-differential >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-circuit >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-index >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-join >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-runtime >= 0.1 && < 0.2
    , tasty-bench >= 0.3 && < 0.5
    , transformers >= 0.6 && < 0.7

source-repository head
  type:     git
  location: https://github.com/PaleRoses/moonlight.git
  subdir:   moonlight-differential
