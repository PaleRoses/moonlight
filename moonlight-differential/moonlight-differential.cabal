cabal-version:       3.0
name:                moonlight-differential
version:             0.1.0.0
homepage:            https://github.com/PaleRoses/moonlight
bug-reports:         https://github.com/PaleRoses/moonlight/issues
synopsis:            Differential maintenance substrate for Moonlight runtimes.
description:
  Runtime-neutral differential maintenance vocabulary: proposition keys,
  runtime time/frontiers, local facts, context restriction registries,
  arrow indexes, generic deltas, update batches, traces, projection work,
  and context-row cache machinery.
license:             MIT
license-file:        LICENSE
author:              Blue Rose
maintainer:          rosaliafialkova@gmail.com
category:            Foundation
build-type:          Simple
tested-with:         GHC == 9.14.1
extra-doc-files:
  README.md
  THIRD_PARTY_NOTICES.md

common shared-properties
  default-language: GHC2024
  build-depends:
    base >= 4.22 && < 5
  ghc-options:
    -Wall
    -Wcompat
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wredundant-constraints
    -Wpartial-fields
    -Wno-missing-import-lists
  default-extensions:
    StrictData

library moonlight-differential-raw
  import: shared-properties
  visibility: private
  hs-source-dirs: src-raw
  exposed-modules:
    Moonlight.Differential.Internal.Index.IndexedRows
    Moonlight.Differential.Internal.Index.Registry
    Moonlight.Differential.Internal.Index.RowId
    Moonlight.Differential.Internal.Index.RowIdSet
    Moonlight.Differential.Internal.Trace.Id
    Moonlight.Differential.Internal.Trace.Indexed
  build-depends:
    containers >= 0.6 && < 0.9
    , moonlight-core >= 0.1 && < 0.2
    , primitive >= 0.8 && < 0.10

library
  import: shared-properties
  hs-source-dirs: src-public
  ghc-options:
    -fomit-interface-pragmas
  exposed-modules:
    Moonlight.Differential
    Moonlight.Differential.Algebra.FiniteMap
    Moonlight.Differential.Algebra.ZSet
    Moonlight.Differential.Arrangement
    Moonlight.Differential.Batch
    Moonlight.Differential.Cursor
    Moonlight.Differential.Delta
    Moonlight.Differential.Frontier
    Moonlight.Differential.Order.LocallyFinite
    Moonlight.Differential.Operator.Aggregate
    Moonlight.Differential.Operator.Fixpoint
    Moonlight.Differential.Operator.Join
    Moonlight.Differential.Operator.Linear
    Moonlight.Differential.Operator.SupportedView
    Moonlight.Differential.Projection.Delta
    Moonlight.Differential.Projection.Maintenance
    Moonlight.Differential.Projection.Propagation
    Moonlight.Differential.Projection.Work
    Moonlight.Differential.Proposition
    Moonlight.Differential.Stream
    Moonlight.Differential.Time
    Moonlight.Differential.Trace
    Moonlight.Differential.Trace.Compact
    Moonlight.Differential.Trace.Description
    Moonlight.Differential.Trace.Id
    Moonlight.Differential.Trace.Indexed
    Moonlight.Differential.Trace.ReadIndex
    Moonlight.Differential.Update
  build-depends:
    containers >= 0.6 && < 0.9
    , moonlight-algebra >= 0.1 && < 0.2
    , moonlight-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-epoch >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-raw >= 0.1 && < 0.2
    , vector >= 0.13 && < 0.14
    , vector-algorithms >= 0.9 && < 0.10

library moonlight-differential-index
  import: shared-properties
  visibility: public
  hs-source-dirs: src-index
  ghc-options:
    -fomit-interface-pragmas
  exposed-modules:
    Moonlight.Differential.Index.Arrow
    Moonlight.Differential.Index.IndexedRows
    Moonlight.Differential.Index.IntSet
    Moonlight.Differential.Index.Registry
    Moonlight.Differential.Index.Reverse
    Moonlight.Differential.Index.Reverse.Batch
    Moonlight.Differential.Row.Block
    Moonlight.Differential.Row.Delta
    Moonlight.Differential.Row.Patch
    Moonlight.Differential.Row.Tuple
    Moonlight.Differential.Index.RowArrangement
    Moonlight.Differential.Index.RowId
    Moonlight.Differential.Index.RowIdSet
    Moonlight.Differential.Index.RowProjection
    Moonlight.Differential.Index.RowSet
    Moonlight.Differential.Index.SmallIntArray
    Moonlight.Differential.Relation
  build-depends:
    containers >= 0.6 && < 0.9
    , hashable >= 1.4 && < 1.6
    , moonlight-algebra >= 0.1 && < 0.2
    , moonlight-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-patch >= 0.1 && < 0.2
    , moonlight-differential >= 0.1 && < 0.2
    , moonlight-differential:moonlight-differential-raw >= 0.1 && < 0.2
    , primitive >= 0.8 && < 0.10
    , unordered-containers >= 0.2 && < 0.3
    , vector >= 0.13 && < 0.14
    , vector-algorithms >= 0.9 && < 0.10
    , vector-th-unbox >= 0.2 && < 0.3

library moonlight-differential-runtime
  import: shared-properties
  visibility: public
  hs-source-dirs: src-runtime
  exposed-modules:
    Moonlight.Differential.Carrier.Address
    Moonlight.Differential.Carrier.Topology
    Moonlight.Differential.Context.Restriction
    Moonlight.Differential.Context.RowsCache
    Moonlight.Differential.Fact.Local
