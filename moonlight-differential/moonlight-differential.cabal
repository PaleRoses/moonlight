    Moonlight.Differential.Effect.Laws.Index
    Moonlight.Differential.Effect.Laws.Operator
    Moonlight.Differential.Effect.Laws.Projection
    Moonlight.Differential.Effect.Laws.Runtime
    Moonlight.Differential.Effect.Laws.Stream
    Moonlight.Differential.Effect.Laws.TimeFrontier
    Moonlight.Differential.Effect.Laws.Trace
    Moonlight.Differential.Effect.Laws.WCOJ
  build-depends:
    containers >= 0.6 && < 0.9
    , moonlight-algebra >= 0.1 && < 0.2
    , moonlight-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-core >= 0.1 && < 0.2
    , moonlight-delta:moonlight-delta-epoch >= 0.1 && < 0.2
    , moonlight-differential >= 0.1 && < 0.2
