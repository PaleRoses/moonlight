    , primitive >= 0.8 && < 0.10
    , unordered-containers >= 0.2 && < 0.3
    , vector >= 0.13 && < 0.14

library moonlight-differential-circuit
  import: shared-properties
  visibility: public
  hs-source-dirs: src-circuit
  exposed-modules:
    Moonlight.Differential.Circuit
    Moonlight.Differential.Circuit.Advance
    Moonlight.Differential.Circuit.Build
    Moonlight.Differential.Circuit.Denotation
    Moonlight.Differential.Circuit.Foreign
    Moonlight.Differential.Circuit.Types
  other-modules:
    Moonlight.Differential.Circuit.Carrier
    Moonlight.Differential.Circuit.Eval
